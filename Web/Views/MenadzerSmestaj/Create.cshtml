@model MyWebApp.Models.Smestaj
@using MyWebApp.Models
@{
    ViewBag.Title = "Novi smeštaj";
    var ddl = ViewBag.MojiAranzmani as SelectList; 

   
    var tipItems = Enum.GetValues(typeof(TipSmestaja))
        .Cast<TipSmestaja>()
        .Select(x => new SelectListItem { Text = x.ToString(), Value = x.ToString() })
        .ToList();
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-wrap {
        max-width: 980px;
    }

   
    .cardx {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 20px;
        box-shadow: 0 18px 40px rgba(0,0,0,.25);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
    }

    .cardx-header {
        padding: 22px 24px 12px;
        background: linear-gradient(90deg, rgba(14,116,144,.25), rgba(34,211,238,.15));
        border-bottom: 1px solid var(--stroke);
    }

    .title-row {
        display: flex;
        align-items: baseline;
        gap: .75rem
    }

        .title-row h2 {
            margin: 0;
            font-weight: 900;
            letter-spacing: .3px;
            background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 2px 20px rgba(34,211,238,.15);
        }

    .badge-new {
        background: rgba(34,211,238,.18);
        color: #062a3a;
        border: 1px solid rgba(34,211,238,.45);
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 800;
        letter-spacing: .2px;
        text-transform: uppercase;
    }

    .cardx-body {
        padding: 22px;
    }

   
    .form-label {
        color: #eaf7ff;
        font-weight: 700;
        letter-spacing: .15px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control::placeholder {
            color: #d7eef6;
            opacity: .85;
        }

    
    .section {
        border-top: 1px dashed rgba(255,255,255,.18);
        padding-top: 18px;
        margin-top: 18px;
    }

        .section h6 {
            font-weight: 900;
            letter-spacing: .2px;
            margin-bottom: 12px;
            background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 2px 20px rgba(34,211,238,.15);
        }

    
    .amenity {
        padding: 12px 14px;
        border: 1px solid var(--stroke);
        border-radius: 12px;
        background: rgba(255,255,255,.05);
        transition: .2s ease;
    }

        .amenity:hover {
            background: rgba(255,255,255,.09);
        }

    .help {
        font-size: .85rem;
        color: var(--text-dim);
    }

    
    .chips {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem
    }

    .chip {
        background: rgba(255,255,255,.09);
        border: 1px solid var(--stroke);
        padding: .15rem .55rem;
        border-radius: 999px;
        font-size: .85rem;
        color: #eaf7ff;
    }

    
    .stars-preview {
        font-size: 1.05rem;
        letter-spacing: .08rem;
        color: #facc15;
    }

    
    .sticky-actions {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background: linear-gradient(180deg, rgba(255,255,255,0), rgba(6,31,53,.35) 40%);
        padding-top: 10px;
    }

 
    .btn {
        border: none;
        font-weight: 900;
        letter-spacing: .2px;
        border-radius: 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }
</style>

<div class="container my-4 page-wrap">
    @using (Html.BeginForm("Create", "MenadzerSmestaj", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
    {
        @Html.AntiForgeryToken()

        <div class="cardx">
            <div class="cardx-header">
                <div class="title-row">
                    <h2>Novi smeštaj</h2>
                    <span class="badge-new">novo</span>
                </div>
                <p class="text-muted mb-0" style="color:var(--text-dim)!important;">Popuni osnovne podatke i izaberi pogodnosti.</p>
            </div>

            <div class="cardx-body">
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                
                <div class="row g-4">
                    <div class="col-12">
                        <label class="form-label">Naziv</label>
                        @Html.TextBoxFor(m => m.Naziv, new { @class = "form-control form-control-lg", required = "required", placeholder = "npr. Paradise Resort" })
                        @Html.ValidationMessageFor(m => m.Naziv, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tip smeštaja</label>
                        @Html.DropDownListFor(m => m.tipSmestaja, tipItems, "-- izaberi tip --",
                            new { @class = "form-select form-select-lg text-bg-info", required = "required", id = "tipSmestaja" })
                        <div class="help mt-1">Izaberi: hotel, vila ili motel.</div>
                    </div>

                    
                    <div class="col-md-6" id="zvezdiceWrap" style="display:none">
                        <label class="form-label">Broj zvezdica (1–5)</label>
                        @Html.TextBoxFor(m => m.BrojZvezdica,
                            new { @class = "form-control", type = "number", min = "1", max = "5", step = "1", id = "brojZvezdica" })
                        <div class="help">Polje je relevantno samo za hotele.</div>
                        <div class="stars-preview mt-1" id="starsPreview"></div>
                    </div>
                </div>

                
                <div class="section">
                    <h6>Pogodnosti</h6>
                    <div class="row g-3">
                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.wifi, new { @class = "form-check-input", role = "switch", id = "wifi" })
                                    @Html.LabelFor(m => m.wifi, "Wi-Fi", htmlAttributes: new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Bežični internet u objektu.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PostojanjeBazena, new { @class = "form-check-input", role = "switch", id = "bazen" })
                                    @Html.LabelFor(m => m.PostojanjeBazena, "Bazen", htmlAttributes: new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Otvoreni ili zatvoreni bazen.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PostojanjeSpaCentra, new { @class = "form-check-input", role = "switch", id = "spa" })
                                    @Html.LabelFor(m => m.PostojanjeSpaCentra, "Spa centar", htmlAttributes: new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Sauna, masaže, wellness.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PrilagodjenoZaOsobeSaInvaliditeton, new { @class = "form-check-input", role = "switch", id = "access" })
                                    @Html.LabelFor(m => m.PrilagodjenoZaOsobeSaInvaliditeton, "Prilagođeno", htmlAttributes: new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Pristup i sadržaji za OSI.</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="help mb-1">Rezime pogodnosti:</div>
                        <div id="amenityChips" class="chips"></div>
                    </div>
                </div>

                
                <div class="section">
                    <h6>Poveži sa aranžmanom</h6>
                    <label class="form-label">U koji aranžman dodaješ ovaj smeštaj?</label>
                    @Html.DropDownList("aranzmanId", ddl, "-- izaberi --", new { @class = "form-select form-select-lg text-bg-info", required = "required" })
                    <div class="help mt-1">Samo tvoji (neobrisani) aranžmani su ponuđeni.</div>
                </div>

               
                <div class="sticky-actions">
                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg px-4">Sačuvaj</button>
                        <a class="btn btn-outline-secondary btn-lg" href="@Url.Action("Index")">Nazad</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section scripts{
    <script src="~/Scripts/menadzerSmestajCreate.js"></script>
}
