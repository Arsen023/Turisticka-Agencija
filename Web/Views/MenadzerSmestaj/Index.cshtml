@model List<MyWebApp.Models.Smestaj>
@{
    ViewBag.Title = "Smeštaji (menadžer)";
    var q = ViewBag.Q as string ?? "";
    bool samoMoji = ViewBag.SamoMoji ?? true;
    bool prikaziObrisane = ViewBag.PrikaziObrisane ?? false; 
    var sort = ViewBag.Sort as string ?? "";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    h2 {
        font-weight: 800;
        letter-spacing: .3px;
        margin-top: .25rem;
        background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 2px 20px rgba(34,211,238,.15);
    }

    
    .filter-card {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.22);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: var(--text);
        padding: 16px 16px 10px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control::placeholder {
            color: #d7eef6;
            opacity: .85;
        }

    .btn {
        border: none;
        font-weight: 800;
        letter-spacing: .2px;
        border-radius: 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-secondary {
        background: linear-gradient(90deg,#64748b,#94a3b8);
        color: #051821;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }

    
    .table-glass {
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--stroke);
        background: rgba(255,255,255,.03);
        box-shadow: 0 10px 26px rgba(0,0,0,.22);
        color: var(--text);
    }

        .table-glass thead th {
            background: linear-gradient(90deg, #0e7490, #22d3ee) !important;
            color: #062a3a !important;
            border: none !important;
            font-weight: 900;
            letter-spacing: .2px;
            vertical-align: middle;
        }

        .table-glass tbody td {
            border-color: rgba(255,255,255,.12) !important;
            color: #eaf7ff;
            vertical-align: middle;
        }

        .table-glass tbody tr:nth-child(odd) {
            background: rgba(255,255,255,.03);
        }

        .table-glass tbody tr:hover {
            background: rgba(255,255,255,.06);
        }

   
    .chip {
        display: inline-block;
        padding: .2rem .55rem;
        border-radius: 999px;
        font-size: .85rem;
        font-weight: 700;
        border: 1px solid;
    }

    .chip-yes {
        background: rgba(34,197,94,.15);
        border-color: rgba(34,197,94,.45);
        color: #bbf7d0;
    }

    .chip-no {
        background: rgba(239,68,68,.15);
        border-color: rgba(239,68,68,.45);
        color: #fecaca;
    }

    .chip-del-no {
        background: rgba(148,163,184,.15);
        border-color: rgba(148,163,184,.45);
        color: #e2e8f0;
    }

    .chip-del-yes {
        background: rgba(244,63,94,.15);
        border-color: rgba(244,63,94,.45);
        color: #fecdd3;
    }

    
    .text-dim {
        color: var(--text-dim);
    }
</style>

<div class="container my-4">
    <h2 class="mb-3">Smeštaji (menadžer)</h2>

    @if (TempData["SmestajOK"] != null)
    {<div class="alert alert-success">@TempData["SmestajOK"]</div>}
    @if (TempData["SmestajERR"] != null)
    {<div class="alert alert-danger">@TempData["SmestajERR"]</div>}

    <div class="filter-card mb-3">
        @using (Html.BeginForm("Index", "MenadzerSmestaj", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label text-dim">Pretraga po nazivu</label>
                    <input class="form-control" type="text" name="q" value="@q" placeholder="Unesi naziv smeštaja…" />
                </div>

                <div class="col-md-2">
                    <label class="form-label text-dim">Sortiranje</label>
                    <select class="form-select text-bg-info" name="sort">
                        <option value="">-- Sortiraj --</option>
                        <option value="nazivAsc" @(sort == "nazivAsc" ? "selected" : "")>Naziv ↑</option>
                        <option value="nazivDesc" @(sort == "nazivDesc" ? "selected" : "")>Naziv ↓</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <div class="form-check mt-4 pt-1">
                        <input class="form-check-input" type="checkbox" id="samoMoji" name="samoMoji" value="true" @(samoMoji ? "checked" : "") />
                        <label class="form-check-label" for="samoMoji">Samo moji</label>
                    </div>
                </div>

                <div class="col-md-4 text-end">
                    <button class="btn btn-primary me-2" type="submit">Primeni</button>
                    <a class="btn btn-secondary" href="@Url.Action("Create")">Novi</a>
                </div>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-bordered align-middle table-glass">
            <thead>
                <tr>
                    <th style="width:30%">Naziv</th>
                    <th style="width:8%">WiFi</th>
                    <th style="width:8%">Bazen</th>
                    <th style="width:8%">Spa</th>
                    <th style="width:14%">Prilagođeno</th>
                 
                    <th style="width:22%">Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model ?? Enumerable.Empty<MyWebApp.Models.Smestaj>())
                {
                    <tr>
                        <td class="fw-semibold">
                            @s.Naziv
                        </td>

                        <td>
                            @if (s.wifi)
                            {<span class="chip chip-yes">Da</span> }
                            else
                            { <span class="chip chip-no">Ne</span>}
                        </td>
                        <td>
                            @if (s.PostojanjeBazena)
                            {<span class="chip chip-yes">Da</span> }
                            else
                            { <span class="chip chip-no">Ne</span>}
                        </td>
                        <td>
                            @if (s.PostojanjeSpaCentra)
                            {<span class="chip chip-yes">Da</span> }
                            else
                            { <span class="chip chip-no">Ne</span>}
                        </td>
                        <td>
                            @if (s.PrilagodjenoZaOsobeSaInvaliditeton)
                            {<span class="chip chip-yes">Da</span> }
                            else
                            { <span class="chip chip-no">Ne</span>}
                        </td>
                        

                        <td>
                            @Html.ActionLink(
                                "Uredi", "Edit", "MenadzerSmestaj",
                                new { id = s.Id },
                                new { @class = "btn btn-sm btn-primary me-1" })

                            @using (Html.BeginForm("Delete", "MenadzerSmestaj", FormMethod.Post, new { @class = "d-inline", onsubmit = "return confirm('Obrisati (logički)?');" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("id", s.Id)
                                <button class="btn btn-sm btn-danger me-1">Obriši</button>
                            }

                            @Html.ActionLink(
                                "Jedinice", "Index", "MenadzerJedinica",
                                new { smestajId = s.Id },
                                new { @class = "btn btn-sm btn-outline-secondary" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
