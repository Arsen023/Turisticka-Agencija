@model MyWebApp.Models.Smestaj
@{
    ViewBag.Title = "Uredi smeštaj";
    var tip = (Model.tipSmestaja + "");
    var jeHotel = tip.Equals("hotel", System.StringComparison.OrdinalIgnoreCase);
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

   
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .wrap {
        max-width: 980px
    }

  
    .cardx {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 20px;
        box-shadow: 0 18px 40px rgba(0,0,0,.25);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
    }

    .cardx-head {
        padding: 22px 26px 10px;
        background: linear-gradient(90deg, rgba(14,116,144,.25), rgba(34,211,238,.15));
        border-bottom: 1px solid var(--stroke);
    }

    .cardx-body {
        padding: 24px;
    }

    
    .title {
        margin: 0;
        font-weight: 900;
        letter-spacing: .3px;
        background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 2px 20px rgba(34,211,238,.15);
    }

    .badge-tip {
        background: rgba(34,211,238,.18);
        color: #062a3a;
        border: 1px solid rgba(34,211,238,.45);
        padding: .3rem .6rem;
        border-radius: 999px;
        font-weight: 800;
    }

    
    .form-label {
        color: #eaf7ff;
        font-weight: 700;
        letter-spacing: .15px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control::placeholder {
            color: #d7eef6;
            opacity: .85;
        }

    
    .section {
        border-top: 1px dashed rgba(255,255,255,.18);
        margin-top: 18px;
        padding-top: 18px;
    }

    
    .amenity {
        padding: 12px 14px;
        border: 1px solid var(--stroke);
        border-radius: 14px;
        background: rgba(255,255,255,.05);
        transition: .2s ease;
    }

        .amenity:hover {
            background: rgba(255,255,255,.09);
        }

    .help {
        font-size: .9rem;
        color: var(--text-dim)
    }

    
    .chips {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem
    }

    .chip {
        background: rgba(255,255,255,.09);
        border: 1px solid var(--stroke);
        border-radius: 999px;
        padding: .2rem .6rem;
        font-size: .85rem;
        color: #eaf7ff;
    }

   
    .stars-preview {
        font-size: 1.1rem;
        letter-spacing: .08rem;
        color: #facc15;
    }

    
    .btn {
        border: none;
        font-weight: 900;
        letter-spacing: .2px;
        border-radius: 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }
</style>

<div class="container my-4 wrap" id="smestajForm" data-tip="@tip">
    <div class="cardx">
        <div class="cardx-head d-flex align-items-center justify-content-between">
            <h2 class="title">Uredi smeštaj #@Model.Id</h2>
            <span class="badge-tip text-uppercase">@Model.tipSmestaja</span>
        </div>

        <div class="cardx-body">
            @using (Html.BeginForm("Edit", "MenadzerSmestaj", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)
                @Html.HiddenFor(m => m.tipSmestaja) 

                <div class="row g-4">
                    <div class="col-md-8">
                        <label class="form-label">Naziv</label>
                        @Html.TextBoxFor(m => m.Naziv,
                            new { @class = "form-control form-control-lg", required = "required", placeholder = "npr. Paradise Resort" })
                        @Html.ValidationMessageFor(m => m.Naziv, "", new { @class = "text-danger" })
                    </div>

                   
                    <div class="col-md-4" id="zvezdiceWrap" style="@(jeHotel ? "" : "display:none")">
                        <label class="form-label">Broj zvezdica (1–5)</label>
                        @Html.TextBoxFor(m => m.BrojZvezdica,
                            new { @class = "form-control", type = "number", min = "1", max = "5", step = "1", placeholder = "1–5", id = Html.IdFor(x => x.BrojZvezdica) })
                        <div class="help">Polje je relevantno samo za hotele.</div>
                        <div class="stars-preview mt-1" id="starsPreview">
                            @if (jeHotel && Model.BrojZvezdica > 0)
                            {
                                var s = Math.Max(0, Math.Min(5, (int)Model.BrojZvezdica));
                                @Html.Raw(new string('★', s))
                                @Html.Raw(new string('☆', 5 - s))
                            }
                        </div>
                    </div>
                </div>

                
                <div class="section">
                    <h6 class="mb-2" style="font-weight:800; letter-spacing:.2px;">Pogodnosti</h6>
                    <div class="row g-3">
                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.wifi, new { @class = "form-check-input", role = "switch", id = "wifi" })
                                    @Html.LabelFor(m => m.wifi, "Wi-Fi", new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Bežični internet u objektu.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PostojanjeBazena, new { @class = "form-check-input", role = "switch", id = "bazen" })
                                    @Html.LabelFor(m => m.PostojanjeBazena, "Bazen", new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Otvoreni ili zatvoreni bazen.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PostojanjeSpaCentra, new { @class = "form-check-input", role = "switch", id = "spa" })
                                    @Html.LabelFor(m => m.PostojanjeSpaCentra, "Spa centar", new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Sauna, masaže, wellness.</div>
                            </div>
                        </div>

                        <div class="col-sm-6 col-lg-3">
                            <div class="amenity">
                                <div class="form-check form-switch m-0">
                                    @Html.CheckBoxFor(m => m.PrilagodjenoZaOsobeSaInvaliditeton, new { @class = "form-check-input", role = "switch", id = "access" })
                                    @Html.LabelFor(m => m.PrilagodjenoZaOsobeSaInvaliditeton, "Prilagođeno", new { @class = "form-check-label fw-semibold" })
                                </div>
                                <div class="help mt-1">Pristup i sadržaji za OSI.</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="help mb-1">Rezime pogodnosti:</div>
                        <div id="amenityChips" class="chips"></div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary btn-lg px-4">Sačuvaj</button>
                    @Html.ActionLink("Nazad", "Index", "MenadzerSmestaj", null, new { @class = "btn btn-outline-secondary btn-lg" })
                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/menadzerSmestajEdit.js"></script>
}
