@model MyWebApp.ViewModels.RegisterManagerViewModel
@{
    ViewBag.Title = "Registruj menadzera";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --txt: #f8fafc;
        --dim: #cfe7f2;
        --ink: #062a3a;
        --chipA: #15c1d1;
        --chipB: #22d3ee;
        --chipText: #052a37;
    }

    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--txt);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-title {
        font-weight: 800;
        letter-spacing: .3px;
        margin: .25rem 0 6px;
        background: linear-gradient(90deg,#fff,#e9f8ff 45%,#fff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 2px 20px rgba(34,211,238,.15);
    }

    .muted {
        color: var(--dim);
    }

    .wrap {
        max-width: 900px;
    }

    .glass {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 20px;
        box-shadow: 0 12px 30px rgba(0,0,0,.25);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
    }

    .card-head {
        padding: 28px 28px 0 28px;
    }

    .card-bodyx {
        padding: 28px;
    }

    .badge-new {
        background: rgba(34,211,238,.18);
        color: #052a3a;
        border: 1px solid rgba(34,211,238,.35);
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 700;
    }

    .form-control, .form-select {
        border-radius: 12px !important;
        border: 1px solid rgba(255,255,255,.35) !important;
        background: linear-gradient(90deg,var(--chipA),var(--chipB)) !important;
        color: var(--chipText) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.45), 0 8px 16px rgba(0,0,0,.18);
    }

        .form-control::placeholder {
            color: #000;
            opacity: .85;
        }

        .form-select option {
            color: #052a37;
            background: #bdf3ff;
        }

        .form-control:focus, .form-select:focus {
            outline: 0;
            border-color: #9ff7ff !important;
            box-shadow: 0 0 0 4px rgba(34,211,238,.35), inset 0 1px 0 rgba(255,255,255,.45) !important;
        }

    .section {
        border-top: 1px dashed rgba(255,255,255,.18);
        padding-top: 18px;
        margin-top: 18px;
    }

    .btn {
        border: none;
        font-weight: 700;
        letter-spacing: .2px;
        border-radius: 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }

    .sticky-actions {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background: linear-gradient(180deg,rgba(255,255,255,0), rgba(6,31,53,.35) 40%);
        padding-top: 10px;
    }
</style>

<div class="container my-4 wrap">
    <div class="glass">
        <div class="card-head">
            <div class="d-flex align-items-baseline gap-2">
                <h2 class="page-title m-0">Novi menadzer</h2>
                <span class="badge-new">admin</span>
            </div>
            <p class="muted mb-0">Unesi podatke o novom menadzera.</p>
        </div>

        <div class="card-bodyx">
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            @using (Html.BeginForm("CreateManager", "Admin", FormMethod.Post, new { @class = "needs-validation" }))
            {
                @Html.AntiForgeryToken()

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Korisnicko ime</label>
                        @Html.TextBoxFor(m => m.KorisnickoIme, new { @class = "form-control form-control-lg", required = "required", placeholder = "npr. menadzer1" })
                        @Html.ValidationMessageFor(m => m.KorisnickoIme, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Lozinka</label>
                        @Html.PasswordFor(m => m.Lozinka, new { @class = "form-control form-control-lg", required = "required", placeholder = "min. 5 karaktera" })
                        @Html.ValidationMessageFor(m => m.Lozinka, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Ime</label>
                        @Html.TextBoxFor(m => m.Ime, new { @class = "form-control", required = "required", placeholder = "Ime" })
                        @Html.ValidationMessageFor(m => m.Ime, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prezime</label>
                        @Html.TextBoxFor(m => m.Prezime, new { @class = "form-control", required = "required", placeholder = "Prezime" })
                        @Html.ValidationMessageFor(m => m.Prezime, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Pol</label>
                        @Html.TextBoxFor(m => m.Pol, new { @class = "form-control", required = "required", placeholder = "npr. M / Z" })
                        @Html.ValidationMessageFor(m => m.Pol, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Datum rodjenja</label>

                        
                        <input type="date"
                               id="dpBirth"
                               class="form-control"
                               required
                               value="@(Model != null && Model.DatumRodjenja != default(DateTime) ? Model.DatumRodjenja.ToString("yyyy-MM-dd") : "")" />

                       
                        <input type="hidden"
                               id="DatumRodjenja"
                               name="DatumRodjenja"
                               value="@(Model != null && Model.DatumRodjenja != default(DateTime) ? Model.DatumRodjenja.ToString("dd/MM/yyyy") : "")" />

                        <div class="form-text muted">Unos preko date-pickera.</div>
                        @Html.ValidationMessageFor(m => m.DatumRodjenja, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Email</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "primer@gmail.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="sticky-actions">
                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-primary btn-lg px-4">Dodaj</button>
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-1"></i>Nazad
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/adminCreateManager.js"></script>
    <script src="~/Scripts/date-ddmmyyyy-picker.js"></script>
}

