@model List<MyWebApp.Models.SmestajnaJedinica>
@using MyWebApp.Models
@{
    var s = ViewBag.Smestaj as Smestaj;   
    ViewBag.Title = "Smeštajne jedinice";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .wrap {
        max-width: 1100px;
    }

   
    .cardx {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.22);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
        color: var(--text);
    }

    .cardx-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--stroke);
        background: linear-gradient(90deg, rgba(14,116,144,.25), rgba(34,211,238,.15));
    }

        .cardx-header h3 {
            margin: 0;
            font-weight: 900;
            letter-spacing: .3px;
            background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 2px 20px rgba(34,211,238,.15);
        }

        .cardx-header .text-muted {
            color: var(--text-dim) !important;
        }

    .cardx-body {
        padding: 20px 24px;
    }

    
    .btn {
        border: none;
        border-radius: 12px;
        font-weight: 800;
        letter-spacing: .2px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5) !important;
        background: transparent;
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }

  
    .table {
        margin-bottom: 0;
    }

        .table td, .table th {
            vertical-align: middle;
            border-color: rgba(255,255,255,.12) !important;
            color: #eaf7ff;
        }

        .table thead th {
            background: linear-gradient(90deg,#0e7490,#22d3ee) !important;
            color: #062a3a !important;
            border: none !important;
            font-weight: 800;
            letter-spacing: .2px;
        }

        .table tbody tr:nth-child(odd) {
            background: rgba(255,255,255,.03);
        }

        .table tbody tr:hover {
            background: rgba(255,255,255,.06);
        }

    
    .badge-soft {
        padding: .35rem .6rem;
        border-radius: 999px;
        font-weight: 800;
        letter-spacing: .2px;
        display: inline-block;
        border: 1px solid transparent;
    }

    .badge-soft-success {
        background: rgba(34,197,94,.18);
        border-color: rgba(34,197,94,.35);
        color: #052b12;
    }

    .badge-soft-danger {
        background: rgba(239,68,68,.18);
        border-color: rgba(239,68,68,.35);
        color: #3a0d0d;
    }

    .badge-soft-secondary {
        background: rgba(148,163,184,.18);
        border-color: rgba(148,163,184,.35);
        color: #0c2d3b;
    }

    .text-muted {
        color: var(--text-dim) !important;
    }
</style>

<div class="container my-4 wrap">
    <div class="cardx">
        <div class="cardx-header d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-1">Smeštajne jedinice</h3>
                <div class="text-muted">Smeštaj: <strong>@(s != null ? s.Naziv : null ?? "—")</strong></div>
            </div>
            <div class="d-flex gap-2">
                @Html.ActionLink("Nazad na smeštaje", "Index", "MenadzerSmestaj", null, new { @class = "btn btn-outline-secondary" })
                @Html.ActionLink("Nova jedinica", "Create", "MenadzerJedinica",
                    new { smestajId = s != null ? s.Id : 0 }, new { @class = "btn btn-primary" })
            </div>
        </div>

        <div class="cardx-body">
            @if (TempData["OK"] != null)
            {<div class="alert alert-success">@TempData["OK"]</div>}
            @if (TempData["ERR"] != null)
            {<div class="alert alert-danger">@TempData["ERR"]</div>}

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:80px">ID</th>
                            <th>Kapacitet</th>
                            <th>Status</th>
                            <th>Cena</th>
                            <th>Ljubimci</th>
                            <th style="width:230px">Akcije</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var j in Model)
                            {
                                
                                var statusClass =
                                    j.Status == StatusSmestajneJedinice.Slobodna ? "badge-soft-success" :
                                    j.Status.ToString().ToLower().Contains("zau") || j.Status.ToString().ToLower().Contains("rez")
                                        ? "badge-soft-danger" : "badge-soft-secondary";

                                <tr>
                                    <td>@j.Id</td>
                                    <td>@j.DozvoljenBrojGostiju osoba</td>
                                    <td><span class="badge-soft @statusClass">@j.Status</span></td>
                                    <td>@(j.CenaZaCeluSmestajnuJedinicu > 0 ? j.CenaZaCeluSmestajnuJedinicu.ToString("N0") + " EUR" : "—")</td>
                                    <td>@(j.DozvoljeniKucniLjubimci ? "Da" : "Ne")</td>
                                    <td>
                                        @Html.ActionLink("Izmeni", "Edit", "MenadzerJedinica",
                                            new { id = j.Id }, new { @class = "btn btn-sm btn-primary me-1" })

                                        @using (Html.BeginForm("Delete", "MenadzerJedinica", FormMethod.Post,
                                                 new { @class = "d-inline", onsubmit = "return confirm('Obrisati ovu jedinicu?');" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("id", j.Id)
                                            <button type="submit" class="btn btn-sm btn-danger">Obriši</button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-muted py-4 text-center">Nema dodatih jedinica.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
