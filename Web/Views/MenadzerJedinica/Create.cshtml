@model MyWebApp.Models.SmestajnaJedinica
@using MyWebApp.Models
@{
    var smestaj = ViewBag.Smestaj as MyWebApp.Models.Smestaj;
    ViewBag.Title = "Nova jedinica";

    var statusItems = Enum.GetValues(typeof(StatusSmestajneJedinice))
                          .Cast<StatusSmestajneJedinice>()
                          .Select(x => new SelectListItem
                          {
                              Text = x.ToString(),
                              Value = x.ToString(),
                              Selected = (Model != null && Model.Status == x)
                          }).ToList();
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-wrap {
        max-width: 960px;
    }

    
    .card {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.22);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: var(--text);
        overflow: hidden;
    }

    
    .card-hero {
        background: linear-gradient(135deg, #0e7490 0%, #22d3ee 100%);
        color: #062a3a;
        border: none;
    }

        .card-hero h2 {
            font-weight: 900;
            letter-spacing: .3px;
            margin: 0;
        }

        .card-hero .sub {
            opacity: .85
        }

    .card-body {
        padding: 24px;
    }

    
    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control::placeholder {
            color: #0b2447;
            opacity: .9;
        }
    
    .form-text {
        color: var(--text-dim);
    }

    
    .form-select.text-bg-info,
    .form-select {
        background-color: rgba(34,211,238,.22) !important;
        color: #062a3a !important;
    }

        .form-select option {
            background: #e6fbff;
            color: #062a3a;
        }

    
    .form-check-input {
        box-shadow: none;
        border-color: rgba(255,255,255,.35);
        background-color: rgba(255,255,255,.15);
    }

        .form-check-input:checked {
            background-color: #22d3ee;
            border-color: #22d3ee;
        }

    label.form-check-label {
        color: #eaf7ff;
    }

   
    .input-group-text.muted {
        background: rgba(255,255,255,.12);
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.28);
        border-right: 0;
        border-radius: 12px 0 0 12px;
    }

    .input-group .form-control.with-unit {
        border-left: 0;
        border-radius: 0 12px 12px 0;
    }

    
    .btn {
        border: none;
        border-radius: 12px;
        font-weight: 900;
        letter-spacing: .2px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-secondary {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
        background: transparent;
    }

        .btn-outline-secondary:hover {
            background: rgba(255,255,255,.12);
        }

    .alert-danger {
        border-radius: 14px;
    }
</style>

<div class="container my-4 page-wrap">
    <div class="card border-0 rounded-4">
     
        <div class="card-hero p-4">
            <h2 class="mb-1">Nova jedinica</h2>
            <div class="sub">Smeštaj: <strong>@(smestaj != null ? smestaj.Naziv : "—")</strong></div>
        </div>

        <div class="card-body">
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            @using (Html.BeginForm("Create", "MenadzerJedinica", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.SmestajID)

                <div class="row g-4">
                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Kapacitet (broj gostiju)</label>
                        @Html.TextBoxFor(m => m.DozvoljenBrojGostiju,
                            new { @class = "form-control form-control-lg", type = "number", min = "1", step = "1", required = "required", placeholder = "npr. 4" })
                        @Html.ValidationMessageFor(m => m.DozvoljenBrojGostiju, "", new { @class = "text-danger" })
                        <div class="form-text">Maksimalan broj osoba u ovoj jedinici.</div>
                    </div>

                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold d-block">Kućni ljubimci</label>
                        <div class="form-check form-switch">
                            @Html.CheckBoxFor(m => m.DozvoljeniKucniLjubimci, new { @class = "form-check-input", id = "petsSwitch" })
                            <label class="form-check-label" for="petsSwitch">Dozvoljeni su kućni ljubimci</label>
                        </div>
                        <div class="form-text">Uključi ako su ljubimci dozvoljeni.</div>
                    </div>

                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Cena za celu jedinicu</label>
                        <div class="input-group">
                            <span class="input-group-text muted">EUR</span>
                            @Html.TextBoxFor(m => m.CenaZaCeluSmestajnuJedinicu,
                                new { @class = "form-control with-unit form-control-lg", type = "number", step = "0.01", min = "0", required = "required", placeholder = "npr. 7999.00" })
                        </div>
                        @Html.ValidationMessageFor(m => m.CenaZaCeluSmestajnuJedinicu, "", new { @class = "text-danger" })
                        <div class="form-text">Unesi ukupan iznos najma jedinice.</div>
                    </div>

                   
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Status</label>
                        @Html.DropDownListFor(m => m.Status, statusItems, new { @class = "form-select form-select-lg text-bg-info", required = "required" })
                        @Html.ValidationMessageFor(m => m.Status, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-4">Sačuvaj</button>
                    @Html.ActionLink("Nazad", "Index", "MenadzerJedinica",
                        new { smestajId = Model.SmestajID },
                        new { @class = "btn btn-outline-secondary btn-lg" })
                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Scripts/menadzerJedinicaCreate.js"></script>
}
