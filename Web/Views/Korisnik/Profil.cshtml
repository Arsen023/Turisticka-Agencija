@model MyWebApp.Models.Korisnik
@{
    ViewBag.Title = "Moj profil";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .profile-wrap {
        max-width: 980px;
    }

    .neo-card {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 12px 32px rgba(0,0,0,.22);
        color: var(--text);
        overflow: hidden;
    }

    .neo-header {
        background: linear-gradient(90deg,#0e7490,#22d3ee);
        color: #062a3a;
        font-weight: 900;
        letter-spacing: .3px;
        border-bottom: 1px solid rgba(255,255,255,.18);
    }

    .form-label {
        color: #eaf7ff;
        font-weight: 600;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control:disabled {
            color: #cfe7f2;
            opacity: 1;
            background: rgba(255,255,255,.05);
        }

        .form-control::placeholder {
            color: #d7eef6;
            opacity: .85;
        }

    .text-danger.small {
        color: #ffd2d2 !important;
    }

    .btn {
        border: none;
        border-radius: 12px;
        font-weight: 800;
        letter-spacing: .2px;
        box-shadow: 0 10px 22px rgba(0,0,0,.22);
    }

    .btn-success {
        background: linear-gradient(90deg,#16a34a,#22c55e);
        color: #052a17;
    }

    .section-title {
        font-weight: 800;
        letter-spacing: .25px;
        margin-bottom: .35rem;
        color: #eaf7ff;
    }

    .profile-bar {
        background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,0));
        border-radius: 12px;
        padding: 10px 14px;
        margin-bottom: 10px;
        border: 1px solid rgba(255,255,255,.14);
    }
</style>

<div class="container profile-wrap mt-5">
    <div class="neo-card">
        <div class="neo-header text-center py-3 fs-4">
            Moj profil
        </div>

        <div class="p-4">
            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success text-center fw-semibold">
                    @ViewBag.Success
                </div>
            }

            @using (Html.BeginForm("Profil", "Korisnik", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                <div class="profile-bar">
                    <span class="me-2">Prijavljen kao:</span>
                    <strong>@Model.KorisnickoIme</strong>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="section-title">Korisnicki podaci</div>
                        
                        <div class="mb-3">
                            <label class="form-label">Korisnicko ime</label>
                            @Html.TextBoxFor(m => m.KorisnickoIme,
                                new { @class = "form-control", placeholder = "npr. marko123", autocomplete = "username" })
                            @Html.ValidationMessageFor(m => m.KorisnickoIme, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <div class="section-title">Bezbednost</div>
                            <label class="form-label">Lozinka</label>
                            @Html.PasswordFor(m => m.Lozinka,
                                new
                                    {
                                    @class = "form-control",
                                    placeholder = "●●●●●●●●",
                                    value = Model.Lozinka 
                                })
                            @Html.ValidationMessageFor(m => m.Lozinka, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="section-title">Licni podaci</div>

                        <div class="mb-3">
                            <label class="form-label">Ime</label>
                            @Html.TextBoxFor(m => m.Ime, new { @class = "form-control", placeholder = "Vaše ime" })
                            @Html.ValidationMessageFor(m => m.Ime, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Prezime</label>
                            @Html.TextBoxFor(m => m.Prezime, new { @class = "form-control", placeholder = "Vaše prezime" })
                            @Html.ValidationMessageFor(m => m.Prezime, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "npr. korisnik@mail.com", type = "email", autocomplete = "email" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Datum rodjenja</label>
                            <input type="date"
                                   id="dpBirth"
                                   class="form-control"
                                   required
                                   value="@(Model != null && Model.DatumRodjenja != default(DateTime) ? Model.DatumRodjenja.ToString("yyyy-MM-dd") : "")" />
                            <input type="hidden"
                                   id="DatumRodjenja"
                                   name="DatumRodjenja"
                                   value="@(Model != null && Model.DatumRodjenja != default(DateTime) ? Model.DatumRodjenja.ToString("dd/MM/yyyy") : "")" />
                            @Html.ValidationMessageFor(m => m.DatumRodjenja, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Pol</label>
                            @Html.DropDownListFor(
                                m => m.Pol,
                                new SelectList(new[] { "M", "Z" }, Model != null ? Model.Pol : null),
                                "-- Izaberite pol --",
                                new { @class = "form-select text-dark" }
                            )
                            @Html.ValidationMessageFor(m => m.Pol, "", new { @class = "text-danger small" })
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-5">
                        Sacuvaj izmene
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts{
    
    <script src="~/Scripts/date-ddmmyyyy-picker.js"></script>
}
