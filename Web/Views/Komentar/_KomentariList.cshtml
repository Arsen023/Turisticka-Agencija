@model List<MyWebApp.Models.Komentar>

<div class="mt-3">
    <h6 class="mb-2">Komentari</h6>
    @if (Model != null && Model.Any())
    {
        <ul class="list-group list-group-flush">
            @foreach (var k in Model)
            {
                <li class="list-group-item px-0">
                    <strong>@k.Turista</strong> (ocena: @k.Ocena)<br />
                    <span class="text-muted">@k.Tekst</span>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted small mb-0">Nema komentara za ovaj smestaj.</p>
    }
</div>

