@{
    ViewBag.Title = "Ostavi komentar";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --txt: #f8fafc;
        --dim: #cfe7f2;
        --ink: #062a3a;
        --chipA: #15c1d1;
        --chipB: #22d3ee;
        --chipText: #052a3a;
    }

   
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--txt);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-title {
        font-weight: 800;
        letter-spacing: .3px;
        margin-top: .25rem;
        background: linear-gradient(90deg,#fff,#e9f8ff 45%,#fff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 2px 20px rgba(34,211,238,.15);
    }

    .muted {
        color: var(--dim);
    }

    .wrap {
        max-width: 820px;
    }

 
    .glass {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 20px;
        box-shadow: 0 12px 30px rgba(0,0,0,.25);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        overflow: hidden;
    }

    .card-head {
        padding: 24px 24px 0 24px;
    }

    .card-bodyx {
        padding: 24px;
    }

    
    .form-control, .form-select {
        border-radius: 12px !important;
        border: 1px solid rgba(255,255,255,.35) !important;
        background: linear-gradient(90deg,var(--chipA),var(--chipB)) !important;
        color: var(--chipText) !important;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.45), 0 8px 16px rgba(0,0,0,.18);
    }

        .form-control::placeholder {
            color: #000;
            opacity: .85;
        }

        .form-control:focus, .form-select:focus {
            outline: 0;
            border-color: #9ff7ff !important;
            box-shadow: 0 0 0 4px rgba(34,211,238,.35), inset 0 1px 0 rgba(255,255,255,.45) !important;
        }

    textarea.form-control {
        min-height: 140px;
    }

   
    .btn {
        border: none;
        font-weight: 700;
        letter-spacing: .2px;
        border-radius: 12px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    
    .rating {
        display: inline-flex;
        flex-direction: row-reverse; 
        gap: .25rem;
        font-size: 1.35rem;
        line-height: 1;
    }

        .rating input {
            display: none;
        }

        .rating label {
            cursor: pointer;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,.25));
            transition: transform .08s ease;
        }

            .rating label:hover {
                transform: scale(1.06);
            }

           
            .rating label::before {
                content: "\f005";
                font-family: "Font Awesome 5 Free";
                font-weight: 400;
                color: #ffffff66;
            }
          
            .rating input:checked ~ label::before,
            .rating label:hover ~ label::before,
            .rating label:hover::before {
                content: "\f005";
                font-family: "Font Awesome 5 Free";
                font-weight: 900;
                color: #facc15;
                text-shadow: 0 0 10px rgba(250,204,21,.35);
            }
</style>

<div class="container my-5 wrap">
    <div class="glass">
        <div class="card-head">
            <h3 class="page-title">Ostavi komentar</h3>
            <p class="muted mb-3">Smeštaj: <strong>@ViewBag.SmestajNaziv</strong></p>
        </div>

        <div class="card-bodyx">
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvori"></button>
                </div>
            }

            @using (Html.BeginForm("Create", "Komentar", FormMethod.Post, new { @class = "needs-validation" }))
            {
                @Html.Hidden("SmestajNaziv", (string)ViewBag.SmestajNaziv)

                <div class="mb-3">
                    <label class="form-label fw-semibold">Tekst komentara</label>
                    <textarea name="tekst" class="form-control" placeholder="Podeli svoje iskustvo…" required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold d-block">Ocena (1–5)</label>

                   
                    <div class="rating" aria-label="Oceni od 1 do 5">
                        <input type="radio" id="star5" name="ocena" value="5">
                        <label for="star5" title="5 zvezdica"></label>

                        <input type="radio" id="star4" name="ocena" value="4">
                        <label for="star4" title="4 zvezdice"></label>

                        <input type="radio" id="star3" name="ocena" value="3" checked>
                        <label for="star3" title="3 zvezdice"></label>

                        <input type="radio" id="star2" name="ocena" value="2">
                        <label for="star2" title="2 zvezdice"></label>

                        <input type="radio" id="star1" name="ocena" value="1">
                        <label for="star1" title="1 zvezdica"></label>
                    </div>
                    <div class="form-text muted mt-1">Klikni na zvezdicu ili ostavi podrazumevano (3).</div>
                </div>

                <button type="submit" class="btn btn-primary px-4">Pošalji</button>
            }
        </div>
    </div>
</div>

