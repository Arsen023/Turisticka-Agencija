@model IEnumerable<MyWebApp.Models.Aranzman>
@{
    ViewBag.Title = "Aranžmani (menadžer)";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-title {
        font-weight: 900;
        letter-spacing: .3px;
        background: linear-gradient(90deg,#fff,#e9f8ff 45%,#ffffff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 2px 20px rgba(34,211,238,.15);
        margin-bottom: 1rem;
    }

    
    .neo-card {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 18px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 12px 32px rgba(0,0,0,.22);
        color: var(--text);
        overflow: hidden;
    }

    .neo-header {
        background: linear-gradient(90deg, #0e7490, #22d3ee);
        color: #062a3a;
        font-weight: 900;
        letter-spacing: .25px;
        border-bottom: 1px solid rgba(255,255,255,.18);
    }

    
    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        background: rgba(255,255,255,.07);
        color: #fff;
    }

        .form-control::placeholder {
            color: #d7eef6;
            opacity: .85;
        }

    .form-check-input {
        width: 2.75rem;
        height: 1.4rem;
        cursor: pointer;
        background: rgba(255,255,255,.15);
        border: 1px solid rgba(255,255,255,.28);
    }

        .form-check-input:checked {
            background: linear-gradient(90deg,#0ea5e9,#22d3ee);
            border-color: transparent;
        }

    .form-check-label {
        color: #eaf7ff;
    }

   
    .btn {
        border: none;
        border-radius: 12px;
        font-weight: 800;
        letter-spacing: .2px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-success {
        background: linear-gradient(90deg,#16a34a,#22c55e);
        color: #052a17;
    }

    .btn-warning {
        background: linear-gradient(90deg,#d97706,#f59e0b);
        color: #2a1400;
    }

    .btn-danger {
        background: linear-gradient(90deg,#ef4444,#f97316);
    }

    
    .table-wrap {
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--stroke);
    }

    table.table {
        margin: 0;
        color: #eaf7ff;
        background: rgba(255,255,255,.03);
    }

    thead.table-light th {
        background: linear-gradient(90deg,#0e7490,#22d3ee) !important;
        color: #062a3a !important;
        border: none !important;
        font-weight: 900;
    }

    tbody tr:nth-child(odd) {
        background: rgba(255,255,255,.03);
    }

    tbody tr:hover {
        background: rgba(255,255,255,.06);
    }

    td, th {
        border-color: rgba(255,255,255,.12) !important;
    }

   
    .badge-soft {
        padding: .35rem .6rem;
        border-radius: 999px;
        font-weight: 700;
        font-size: .75rem;
        border: 1px solid rgba(255,255,255,.18);
    }

    .badge-ok {
        background: rgba(34,197,94,.15);
        color: #b9f6c4;
        border-color: rgba(34,197,94,.35);
    }

    .badge-del {
        background: rgba(239,68,68,.15);
        color: #ffd1c8;
        border-color: rgba(239,68,68,.35);
    }
</style>

<div class="container mt-4">
    @if (TempData["AranzmanOK"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["AranzmanOK"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["AranzmanERR"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["AranzmanERR"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <h2 class="page-title">Aranžmani (menadžer)</h2>


    <div class="neo-card mb-3">
        <div class="neo-header py-2 px-3">Filteri i sortiranje</div>
        <div class="p-3">
            @using (Html.BeginForm("Index", "MenadzerAranzman", FormMethod.Get, new { @class = "row g-2 align-items-end" }))
            {
                <div class="col-md-5">
                    <label class="form-label">Pretraga po nazivu/opisu</label>
                    <input name="q" value="@ViewBag.Q" class="form-control" placeholder="Unesi tekst…" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Sortiraj</label>
                    <select name="sort" class="form-select text-bg-info">
                        <option value="">—</option>
                        <option value="nazivAsc" @(ViewBag.Sort == "nazivAsc" ? "selected" : "")>Naziv ↑</option>
                        <option value="nazivDesc" @(ViewBag.Sort == "nazivDesc" ? "selected" : "")>Naziv ↓</option>
                        <option value="pocetakAsc" @(ViewBag.Sort == "pocetakAsc" ? "selected" : "")>Početak ↑</option>
                        <option value="pocetakDesc" @(ViewBag.Sort == "pocetakDesc" ? "selected" : "")>Početak ↓</option>
                    </select>
                </div>



                <div class="col-md-2">
                    <button class="btn btn-primary w-100">Primeni</button>
                </div>
            }
        </div>
    </div>


    <div class="mb-3">
        @Html.ActionLink("➕ Novi aranžman", "Create", "MenadzerAranzman", null, new { @class = "btn btn-success" })
    </div>


    <div class="neo-card">
        <div class="neo-header py-2 px-3">Lista aranžmana</div>
        <div class="table-wrap">
            <table class="table table-bordered table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Naziv</th>
                        <th>Početak</th>
                        <th>Kraj</th>

                        <th style="width:220px;">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model ?? Enumerable.Empty<MyWebApp.Models.Aranzman>())
                    {
                        var isDel = a.IsDeleted;
                        <tr>
                            <td class="fw-semibold">@a.Naziv</td>
                            <td>@a.DatumPocetkaPutovanja.ToShortDateString()</td>
                            <td>@a.DatumZavrsetkaPutovanja.ToShortDateString()</td>

                            <td>
                                @Html.ActionLink("Detalji", "Details", "MenadzerAranzman",
                                    new { id = a.Id }, new { @class = "btn btn-outline-light btn-sm me-1", @style = "border-color:rgba(255,255,255,.5)" })

                                @Html.ActionLink("Izmeni", "Edit", "MenadzerAranzman",
                                    new { id = a.Id }, new { @class = "btn btn-warning btn-sm me-1" })

                                @using (Html.BeginForm("Delete", "MenadzerAranzman", FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", a.Id)
                                    <button type="submit" class="btn btn-danger btn-sm"
                                            onclick="return confirm('Da li sigurno brišeš?')">
                                        Obriši
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
