@model MyWebApp.Models.Aranzman
@{
    ViewBag.Title = "Detalji aranžmana";
}

<style>
    :root {
        --c-deep: #0b2447;
        --c-mid: #0e7490;
        --c-sky: #22d3ee;
        --glass: rgba(255,255,255,.08);
        --stroke: rgba(255,255,255,.18);
        --text: #f8fafc;
        --text-dim: #cfe7f2;
    }

    
    body {
        min-height: 100vh;
        background: radial-gradient(1200px 600px at -10% -10%, rgba(255,255,255,.06), transparent 60%), radial-gradient(900px 600px at 110% 10%, rgba(255,255,255,.05), transparent 50%), linear-gradient(135deg, var(--c-deep) 0%, #0a3a5a 35%, var(--c-mid) 68%, var(--c-sky) 110%);
        color: var(--text);
    }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' opacity='.05'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
            mix-blend-mode: overlay;
        }

    .page-wrap {
        max-width: 980px;
    }

    
    .neo-card {
        background: var(--glass);
        border: 1px solid var(--stroke);
        border-radius: 20px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 14px 34px rgba(0,0,0,.22);
        overflow: hidden;
    }

    .neo-hero {
        background: linear-gradient(90deg,#0e7490,#22d3ee);
        color: #062a3a;
        padding: 22px 26px;
        border-bottom: 1px solid rgba(255,255,255,.18);
    }

        .neo-hero h2 {
            margin: 0;
            font-weight: 900;
            letter-spacing: .3px;
        }

        .neo-hero .sub {
            font-weight: 700;
            opacity: .85;
        }

    .status-pill {
        background: #062a3a;
        color: #aaf2ff;
        border: 1px solid rgba(255,255,255,.3);
        padding: .35rem .75rem;
        border-radius: 999px;
        font-weight: 800;
        letter-spacing: .2px;
    }

        .status-pill.danger {
            background: #4b1e1e;
            color: #ffd7d7;
            border-color: #ffb3b3;
        }

    .neo-body {
        padding: 1.25rem 1.5rem 1.75rem;
    }

    
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 18px;
        margin-top: 10px;
    }

    .info-item .k {
        font-size: .85rem;
        font-weight: 800;
        color: #cfe7f2;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .info-item .v {
        margin-top: 6px;
        padding: 10px 14px;
        border-radius: 12px;
        background: rgba(255,255,255,.06);
        border: 1px solid var(--stroke);
        color: #fff;
        font-weight: 700;
    }

    .desc-wrap {
        margin-top: 18px;
        border: 1px solid var(--stroke);
        background: rgba(255,255,255,.05);
        border-radius: 14px;
        padding: 14px;
        color: var(--text-dim);
    }

    
    .btn {
        border: none;
        border-radius: 12px;
        font-weight: 900;
        letter-spacing: .2px;
        box-shadow: 0 10px 24px rgba(0,0,0,.22);
    }

    .btn-primary {
        background: linear-gradient(90deg,#0ea5e9,#22d3ee);
        color: #053b4c;
    }

    .btn-outline-light {
        color: #eaf7ff;
        border: 1px solid rgba(255,255,255,.5);
    }

        .btn-outline-light:hover {
            background: rgba(255,255,255,.12);
        }
</style>

<div class="container my-4 page-wrap">
    <div class="neo-card">

        
        <div class="neo-hero">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h2>@Model.Naziv</h2>
                    <div class="sub">Detalji aranžmana</div>
                </div>
                <span class="status-pill @(Model.IsDeleted ? "danger" : "")">
                    @(Model.IsDeleted ? "OBRISAN" : "AKTIVAN")
                </span>
            </div>
        </div>

       
        <div class="neo-body">

            
            <div class="detail-grid">
                <div class="info-item">
                    <div class="k">Početak</div>
                    <div class="v">@Model.DatumPocetkaPutovanja.ToShortDateString()</div>
                </div>
                <div class="info-item">
                    <div class="k">Kraj</div>
                    <div class="v">@Model.DatumZavrsetkaPutovanja.ToShortDateString()</div>
                </div>

               
                <div class="info-item">
                    <div class="k">Tip aranžmana</div>
                    <div class="v">@Model.tipAranzmana</div>
                </div>
                <div class="info-item">
                    <div class="k">Prevoz</div>
                    <div class="v">@Model.tipPrevoza</div>
                </div>
                <div class="info-item">
                    <div class="k">Lokacija</div>
                    <div class="v">@Model.lokacija</div>
                </div>
                <div class="info-item">
                    <div class="k">Maks. putnika</div>
                    <div class="v">@Model.MaxBrPutnika</div>
                </div>
            </div>

           
            <div class="desc-wrap">
                <div class="k" style="text-transform:uppercase; font-weight:800; letter-spacing:.06em;">Opis</div>
                <div class="mt-1">
                    @(String.IsNullOrWhiteSpace(Model.OpisAranzmana) ? "—" : Model.OpisAranzmana)
                </div>
            </div>

            
            <div class="mt-4 d-flex gap-2">
                @Html.ActionLink("Nazad", "Index", "MenadzerAranzman", null, new { @class = "btn btn-outline-light" })
            </div>
        </div>
    </div>
</div>
