@model IEnumerable<MyWebApp.Models.Aranzman>

@{
    ViewBag.Title = "Dostupni aranžmani";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.9) 0%, rgba(118, 75, 162, 0.9) 50%, rgba(240, 147, 251, 0.9) 100%);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 4rem 2rem;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: white;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        background: linear-gradient(45deg, #fff, #e3f2fd);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .hero-subtitle {
        font-size: 1.25rem;
        font-weight: 400;
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .search-section {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 3rem;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    }

    .search-title {
        color: white;
        font-weight: 700;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .form-control, .form-select {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        color: white;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.5);
        box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.25);
        color: white;
    }

    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.7);
    }

    .form-label {
        color: rgba(255, 255, 255, 0.9);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .trip-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .trip-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }

    .trip-card .card-img-top {
        height: 220px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .trip-card:hover .card-img-top {
        transform: scale(1.1);
    }

    .trip-card .card-body {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
        color: white;
        padding: 1.5rem;
    }

    .trip-card .card-title {
        color: white;
        font-weight: 700;
        font-size: 1.25rem;
        margin-bottom: 1rem;
    }

    .trip-card .card-text {
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.6;
    }

    .trip-card .card-text strong {
        color: rgba(255, 255, 255, 0.95);
    }

    .btn-search {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-search:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
        color: white;
    }

    .btn-outline-primary {
        border: 2px solid rgba(255, 255, 255, 0.5);
        color: white;
        background: transparent;
        border-radius: 12px;
        padding: 0.5rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-outline-primary:hover {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
        color: white;
        transform: translateY(-2px);
    }

    .section-title {
        color: white;
        font-weight: 800;
        font-size: 2.5rem;
        margin-bottom: 2rem;
        text-align: center;
        background: linear-gradient(45deg, #fff, #e3f2fd);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .no-trips {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .no-trips i {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }
        
        .hero-subtitle {
            font-size: 1rem;
        }
        
        .search-section {
            padding: 1.5rem;
        }
        
        .trip-card:hover {
            transform: translateY(-5px) scale(1.01);
        }
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="hero-content">
        <h1 class="hero-title">
            <i class="fas fa-globe-americas me-3"></i>
            Otkrijte svet
        </h1>
        <p class="hero-subtitle">
            Pronađite savršene aranžmane za nezaboravna putovanja. Vaša avantura počinje ovde!
        </p>
    </div>
</div>

<!-- Search and Filter Section -->
<div class="search-section">
    <h3 class="search-title">
        <i class="fas fa-search me-2"></i>
        Pretražite aranžmane
    </h3>
    
    @using (Html.BeginForm("Index", "Home", FormMethod.Get))
    {
        <div class="row g-3">
            <div class="col-md-3">
                <label for="naziv" class="form-label">
                    <i class="fas fa-map-marker-alt me-1"></i>
                    Naziv aranžmana
                </label>
                <input type="text" id="naziv" name="naziv" class="form-control" placeholder="Unesite naziv aranžmana" />
            </div>
            
            <div class="col-md-2">
                <label for="datumOd" class="form-label">
                    <i class="fas fa-calendar-alt me-1"></i>
                    Datum polaska (od)
                </label>
                <input type="date" id="datumOd" name="datumOd" class="form-control" />
            </div>
            
            <div class="col-md-2">
                <label for="datumDo" class="form-label">
                    <i class="fas fa-calendar-alt me-1"></i>
                    Datum polaska (do)
                </label>
                <input type="date" id="datumDo" name="datumDo" class="form-control" />
            </div>
            
            <div class="col-md-2">
                <label for="tipPrevoza" class="form-label">
                    <i class="fas fa-plane me-1"></i>
                    Tip prevoza
                </label>
                <select id="tipPrevoza" name="tipPrevoza" class="form-select">
                    <option value="">Svi tipovi</option>
                    <option value="avion">Avion</option>
                    <option value="autobus">Autobus</option>
                    <option value="autobus_avion">Bus + Avion</option>
                    <option value="individualan">Individualan</option>
                </select>
            </div>
            
             <div class="col-md-3">
                 <label for="tipAranzmana" class="form-label">
                     <i class="fas fa-bed me-1"></i>
                     Tip aranžmana
                 </label>
                 <select id="tipAranzmana" name="tipAranzmana" class="form-select">
                     <option value="">Svi tipovi</option>
                     <option value="nocenje_sa_doruckom">Noćenje + doručak</option>
                     <option value="polupansion">Polupansion</option>
                     <option value="pun_pansion">Pun pansion</option>
                     <option value="all_inclusive">All inclusive</option>
                     <option value="najam_apartamana">Najam apartmana</option>
                 </select>
             </div>
        </div>
        
        <div class="row g-3 mt-3">
            <div class="col-md-3">
                <label for="krajOd" class="form-label">
                    <i class="fas fa-calendar-check me-1"></i>
                    Datum završetka (od)
                </label>
                <input type="date" id="krajOd" name="krajOd" class="form-control" />
            </div>
            
            <div class="col-md-3">
                <label for="krajDo" class="form-label">
                    <i class="fas fa-calendar-check me-1"></i>
                    Datum završetka (do)
                </label>
                <input type="date" id="krajDo" name="krajDo" class="form-control" />
            </div>
            
            <div class="col-md-3">
                <label for="sort" class="form-label">
                    <i class="fas fa-sort me-1"></i>
                    Sortiraj po
                </label>
                <select id="sort" name="sort" class="form-select">
                    <option value="">Izaberite kriterijum</option>
                    <option value="nazivAsc">Naziv (A → Z)</option>
                    <option value="nazivDesc">Naziv (Z → A)</option>
                    <option value="pocetakAsc">Datum početka (rastuće)</option>
                    <option value="pocetakDesc">Datum početka (opadajuće)</option>
                    <option value="krajAsc">Datum završetka (rastuće)</option>
                    <option value="krajDesc">Datum završetka (opadajuće)</option>
                </select>
            </div>
            
             <div class="col-md-3 d-flex align-items-end">
                 <button type="submit" class="btn btn-search w-100 me-2">
                     <i class="fas fa-search me-1"></i>
                     Pretraži
                 </button>
                 <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary w-100">
                     <i class="fas fa-refresh me-1"></i>
                     Resetuj
                 </a>
             </div>
        </div>
    }
</div>


<!-- Trips Section -->
<h2 class="section-title">
    <i class="fas fa-map-marked-alt me-3"></i>
    Dostupni aranžmani
</h2>

@if (Model.Any())
{
    <div class="row">
        @foreach (var a in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 trip-card">
                    <div class="position-relative">
                        <img src="~/Content/Images/@a.PosterAranzmana" class="card-img-top" alt="@a.Naziv" />
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-primary px-3 py-2 rounded-pill">
                                <i class="fas fa-users me-1"></i>
                                @a.MaxBrPutnika putnika
                            </span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@a.Naziv</h5>
                        <div class="card-text flex-grow-1">
                            <div class="mb-2">
                                <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                                <strong>@a.lokacija</strong>
                            </div>
                            <div class="mb-2">
                                <i class="fas fa-bed me-2 text-info"></i>
                                <span>@a.tipAranzmana</span>
                            </div>
                            <div class="mb-2">
                                <i class="fas fa-plane me-2 text-success"></i>
                                <span>@a.tipPrevoza</span>
                            </div>
                            <div class="mb-3">
                                <i class="fas fa-calendar-alt me-2 text-warning"></i>
                                <span>@a.DatumPocetkaPutovanja.ToShortDateString() - @a.DatumZavrsetkaPutovanja.ToShortDateString()</span>
                            </div>
                        </div>
                        <div class="mt-auto">
                            @Html.ActionLink(
                                "Detaljnije",
                                "Detalji",
                                "Home",
                                new { naziv = a.Naziv },
                                new { @class = "btn btn-outline-primary w-100" }
                            )
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="no-trips">
        <i class="fas fa-search"></i>
        <h3>Nema rezultata</h3>
        <p>Pokušajte da promenite kriterijume pretrage ili resetujte filtere.</p>
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">
            <i class="fas fa-refresh me-2"></i>
            Resetuj filtere
        </a>
    </div>
}